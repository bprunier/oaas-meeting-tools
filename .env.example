# Chemin vers la base de données SQLite
DB_PATH=audio_analysis.db

# Taille du modèle Whisper : tiny | base | small | medium | large-v3
# Plus grand = plus précis mais plus lent (base recommandé pour commencer)
WHISPER_MODEL_SIZE=base

# Langue audio (laisser vide pour auto-détection)
# Exemples : fr, en, es, de
AUDIO_LANGUAGE=

# Temps de parole minimum (secondes) pour inclure un locuteur dans la synthèse
MIN_SPEAKING_TIME=5

# Ollama (LLM local pour sentiment + résumé)
# Installer Ollama : https://ollama.com  (gratuit, tourne en local)
# Puis : ollama pull llama3
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3
